{
  "Proxy": {
    "HostAliases": [
      {
        "Alias": "openai.local",
        "Target": "https://api.openai.com"
      }
    ],
    "HeaderInjections": [
      {
        "Host": "openai.local",
        "PathRegex": "^/v1/",
        "BearerToken": "replace-with-token"
      },
      {
        "Host": "api.example.local",
        "Authorization": "Bearer replace-with-full-authorization-header-value"
      },
      {
        "PathRegex": "^/internal/",
        "Headers": {
          "X-Api-Key": "replace-with-api-key",
          "X-Client": "LlmHub"
        }
      }
    ]
  },
  "HttpApis": {
    "Endpoints": [
      {
        "Name": "azure-devops",
        "BaseUrl": "https://dev.azure.com/replace-with-organization/replace-with-project/_apis/",
        "Description": "Azure DevOps REST API for one organization project.",
        "Examples": [
          "git/repositories",
          "wit/workitems/{id}",
          "build/builds"
        ],
        "BasicCredentials": "replace-with-user:replace-with-pat",
        "Query": {
          "api-version": "7.1"
        },
        "Headers": {
          "Accept": "application/json"
        },
        "Requests": {
          "repositories": {
            "Method": "GET",
            "Path": "git/repositories",
            "Description": "Lists Git repositories in the configured project."
          },
          "work-item": {
            "Method": "GET",
            "Path": "wit/workitems/{id}",
            "Description": "Gets one work item by id."
          },
          "builds": {
            "Method": "GET",
            "Path": "build/builds",
            "Description": "Lists builds in the configured project."
          }
        }
      },
      {
        "Name": "example-api",
        "BaseUrl": "https://api.example.com/v1/",
        "Description": "Example bearer-token API.",
        "Examples": [
          "resources",
          "resources/{id}"
        ],
        "BearerToken": "replace-with-token",
        "Headers": {
          "Accept": "application/json"
        }
      }
    ]
  },
  "Databases": {
    "Profiles": [
      {
        "Name": "local-postgres",
        "Provider": "postgres",
        "Host": "localhost",
        "Port": 5432,
        "Username": "postgres",
        "Password": "replace-with-password",
        "SslMode": "Prefer",
        "TrustServerCertificate": true,
        "Options": {
          "Pooling": "true",
          "Timeout": "15"
        }
      }
    ],
    "Connections": [
      {
        "Name": "local-postgres",
        "Profile": "local-postgres",
        "Database": "app"
      },
      {
        "Name": "test-postgres",
        "Profile": "local-postgres",
        "Database": "test"
      }
    ]
  }
}
