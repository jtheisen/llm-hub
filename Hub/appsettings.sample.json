{
  "Proxy": {
    "HostAliases": [
      {
        "Alias": "openai.local",
        "Target": "https://api.openai.com"
      }
    ],
    "HeaderInjections": [
      {
        "Host": "openai.local",
        "PathRegex": "^/v1/",
        "BearerToken": "replace-with-token"
      },
      {
        "Host": "api.example.local",
        "Authorization": "Bearer replace-with-full-authorization-header-value"
      },
      {
        "PathRegex": "^/internal/",
        "Headers": {
          "X-Api-Key": "replace-with-api-key",
          "X-Client": "LlmHub"
        }
      }
    ]
  },
  "HttpApis": {
    "Endpoints": [
      {
        "Name": "azure-devops",
        "BaseUrl": "https://dev.azure.com/replace-with-organization/replace-with-project/_apis/",
        "BasicToken": "replace-with-user:replace-with-pat",
        "Query": {
          "api-version": "7.1"
        },
        "Headers": {
          "Accept": "application/json"
        }
      },
      {
        "Name": "example-api",
        "BaseUrl": "https://api.example.com/v1/",
        "BearerToken": "replace-with-token",
        "Headers": {
          "Accept": "application/json"
        }
      }
    ]
  },
  "Databases": {
    "Profiles": [
      {
        "Name": "local-postgres",
        "Provider": "postgres",
        "Host": "localhost",
        "Port": 5432,
        "Username": "postgres",
        "Password": "replace-with-password",
        "SslMode": "Prefer",
        "TrustServerCertificate": true,
        "Options": {
          "Pooling": "true",
          "Timeout": "15"
        }
      }
    ],
    "Connections": [
      {
        "Name": "local-postgres",
        "Profile": "local-postgres",
        "Database": "app"
      },
      {
        "Name": "test-postgres",
        "Profile": "local-postgres",
        "Database": "test"
      }
    ]
  }
}
